  "description": "Token-efficiency rules, skill routing, enforcement hooks, and cross-platform AGENTS.md generation for Claude Code.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "node --test 'tests/unit/*.test.js' 'tests/integration/*.test.js'",
